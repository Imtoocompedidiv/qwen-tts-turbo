RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_SSH_KEY=ssh-ed25519 AAAA... user@host
RUNPOD_VOLUME_ID=           # Optional: pre-provisioned network volume ID
